    "clean": "rm -rf dist .turbo",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@prisma/adapter-pg": "^6.19.0",
    "pg": "^8.13.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@meest/config": "workspace:*",
    "@types/node": "^22.10.1",
    "prisma": "^6.19.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.3",
    "tsx": "^4.19.2"
  }
}