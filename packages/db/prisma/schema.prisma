// Prisma schema for meest-returns.
//
// Domain: returns logistics platform connecting consumers, PUDO drop-off
// points, e-commerce merchants, and the Dębica sorting hub.
//
// Conventions:
//   - All primary keys are cuid strings.
//   - Money is Decimal(12,2) (PLN-scale); ledger balances are Decimal(14,2).
//   - Consumer score is Decimal(3,2) on a 0.00–5.00 range.
//   - Lat/lon are Decimal(10,7) (~1cm precision).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum RefundPolicy {
  INSTANT_AT_PUDO
  AFTER_HUB_RECEIPT
  AFTER_INSPECTION
}

enum ReturnStatus {
  INITIATED
  DROPPED_OFF
  IN_TRANSIT
  AT_HUB
  SORTED
  SHIPPED_TO_MERCHANT
  COMPLETED
  REJECTED
  EXPIRED
}

enum ReturnReason {
  WRONG_SIZE
  NOT_AS_DESCRIBED
  LOW_QUALITY
  CHANGED_MIND
  DAMAGED
  OTHER
}

// State of the merchant-side payout reservation tied to a Return.
enum RefundStatus {
  PENDING
  RESERVED
  RELEASED
  FAILED
  CANCELLED
}

enum BagStatus {
  OPEN
  CLOSED
  IN_TRANSIT
  RECEIVED_AT_HUB
}

enum ActorType {
  CONSUMER
  OPERATOR
  HUB_STAFF
  SYSTEM
  MERCHANT
}

enum PhotoType {
  AT_PUDO
  AT_HUB
}

// State of the actual outbound payment in the Refund table.
enum RefundProcessStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RefundMethod {
  CARD
  BANK_TRANSFER
  STORE_CREDIT
}

enum DepositTransactionType {
  TOPUP
  RESERVATION
  RELEASE
  REFUND_PAYOUT
  FEE
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

enum ShipmentDestinationType {
  HUB_DEBICA
  MERCHANT
}

enum ShipmentStatus {
  SCHEDULED
  IN_TRANSIT
  DELIVERED
}

enum HubOperatorRole {
  OPERATOR
  SUPERVISOR
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

model Merchant {
  id                   String   @id @default(cuid())
  name                 String
  email                String   @unique
  apiKey               String   @unique
  webhookUrl           String?
  depositBalance       Decimal  @default(0)      @db.Decimal(14, 2)
  depositMinimum       Decimal  @default(5000)   @db.Decimal(14, 2)
  refundPolicy         RefundPolicy @default(AFTER_HUB_RECEIPT)
  autoApproveThreshold Decimal  @default(500)    @db.Decimal(12, 2)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  returns              Return[]
  depositTransactions  DepositTransaction[]
  webhookDeliveries    WebhookDelivery[]
}

model Consumer {
  id              String   @id @default(cuid())
  email           String
  phone           String?
  score           Decimal  @default(4.0) @db.Decimal(3, 2)
  returnsCount    Int      @default(0)
  rejectionsCount Int      @default(0)
  flagged         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  returns     Return[]
  scoreEvents ConsumerScoreEvent[]

  @@index([email])
}

model PudoPoint {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  address       String
  city          String
  postalCode    String
  latitude      Decimal  @db.Decimal(10, 7)
  longitude     Decimal  @db.Decimal(10, 7)
  openingHours  Json
  active        Boolean  @default(true)
  // Pointer to whichever Bag is currently open at the point. Kept as a plain
  // string (not a relation) so we can null it out without juggling a circular
  // FK during shift handovers.
  currentBagId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  operators PudoOperator[]
  returns   Return[]
  bags      Bag[]
  shipments Shipment[]
}

model PudoOperator {
  id          String    @id @default(cuid())
  pudoPointId String
  name        String
  pinHash     String
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?

  pudoPoint PudoPoint @relation(fields: [pudoPointId], references: [id], onDelete: Cascade)

  @@index([pudoPointId])
}

model Return {
  id              String       @id @default(cuid())
  returnId        String       @unique // human-readable, format "RTN-XXXX-XXXX"

  merchantId      String
  merchantOrderId String       // e.g. "MOD-2026-00428"

  consumerId      String
  pudoPointId     String
  bagId           String?

  status          ReturnStatus @default(INITIATED)
  reason          ReturnReason
  reasonComment   String?

  refundAmount    Decimal      @db.Decimal(12, 2)
  refundCurrency  String       @default("PLN")
  refundStatus    RefundStatus @default(PENDING)

  qrToken         String       @unique
  qrExpiresAt     DateTime     @default(dbgenerated("now() + interval '14 days'"))

  // { name, color, size, brand, sku, imageUrl, price }
  productSnapshot Json
  rejectionReason String?

  createdAt       DateTime     @default(now())
  droppedOffAt    DateTime?
  receivedAtHubAt DateTime?
  completedAt     DateTime?

  merchant            Merchant             @relation(fields: [merchantId], references: [id])
  consumer            Consumer             @relation(fields: [consumerId], references: [id])
  pudoPoint           PudoPoint            @relation(fields: [pudoPointId], references: [id])
  bag                 Bag?                 @relation(fields: [bagId], references: [id])

  events              ReturnEvent[]
  photos              ReturnPhoto[]
  refund              Refund?
  depositTransactions DepositTransaction[]
  scoreEvents         ConsumerScoreEvent[]
  webhookDeliveries   WebhookDelivery[]

  @@index([merchantId])
  @@index([consumerId])
  @@index([pudoPointId])
  @@index([bagId])
  @@index([status])
  @@index([merchantOrderId])
}

model Bag {
  id              String    @id @default(cuid())
  bagCode         String    @unique // format "BAG-PUDO-XXXX"
  pudoPointId     String
  status          BagStatus @default(OPEN)
  capacity        Int       @default(12)
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  receivedAtHubAt DateTime?

  pudoPoint PudoPoint @relation(fields: [pudoPointId], references: [id])
  returns   Return[]

  @@index([pudoPointId])
  @@index([status])
}

model ReturnEvent {
  id        String   @id @default(cuid())
  returnId  String
  // INITIATED | QR_GENERATED | SCANNED_AT_PUDO | ACCEPTED_AT_PUDO |
  // REJECTED_AT_PUDO | BAG_CLOSED | ARRIVED_AT_HUB | SORTED_AT_HUB |
  // SHIPPED_TO_MERCHANT | REFUND_TRIGGERED | REFUND_COMPLETED
  eventType String
  actorType ActorType
  actorId   String?
  metadata  Json
  createdAt DateTime @default(now())

  return Return @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([eventType])
}

model ReturnPhoto {
  id        String    @id @default(cuid())
  returnId  String
  photoUrl  String
  photoType PhotoType
  takenAt   DateTime  @default(now())

  return Return @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
}

model Refund {
  id                    String              @id @default(cuid())
  returnId              String              @unique
  amount                Decimal             @db.Decimal(12, 2)
  currency              String              @default("PLN")
  status                RefundProcessStatus @default(PENDING)
  method                RefundMethod
  merchantTransactionId String?
  processedAt           DateTime?
  createdAt             DateTime            @default(now())

  return Return @relation(fields: [returnId], references: [id], onDelete: Cascade)
}

model DepositTransaction {
  id           String                 @id @default(cuid())
  merchantId   String
  type         DepositTransactionType
  // Signed amount (negative for RESERVATION/REFUND_PAYOUT/FEE).
  amount       Decimal                @db.Decimal(14, 2)
  balanceAfter Decimal                @db.Decimal(14, 2)
  returnId     String?
  description  String
  createdAt    DateTime               @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id])
  return   Return?  @relation(fields: [returnId], references: [id])

  @@index([merchantId])
  @@index([returnId])
}

model ConsumerScoreEvent {
  id          String   @id @default(cuid())
  consumerId  String
  scoreChange Decimal  @db.Decimal(3, 2)
  scoreAfter  Decimal  @db.Decimal(3, 2)
  reason      String
  returnId    String?
  createdAt   DateTime @default(now())

  consumer Consumer @relation(fields: [consumerId], references: [id])
  return   Return?  @relation(fields: [returnId], references: [id])

  @@index([consumerId])
  @@index([returnId])
}

model WebhookDelivery {
  id             String                @id @default(cuid())
  merchantId     String
  returnId       String?
  url            String
  payload        Json
  responseStatus Int?
  attemptCount   Int                   @default(0)
  lastAttemptAt  DateTime?
  status         WebhookDeliveryStatus @default(PENDING)
  createdAt      DateTime              @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id])
  return   Return?  @relation(fields: [returnId], references: [id])

  @@index([merchantId])
  @@index([returnId])
  @@index([status])
}

model Shipment {
  id                    String                  @id @default(cuid())
  shipmentCode          String                  @unique
  originPudoPointId     String
  destinationType       ShipmentDestinationType
  // Free-form merchant identifier when destinationType=MERCHANT; null for HUB_DEBICA.
  destinationMerchantId String?
  status                ShipmentStatus          @default(SCHEDULED)
  departedAt            DateTime?
  arrivedAt             DateTime?
  createdAt             DateTime                @default(now())

  originPudoPoint PudoPoint @relation(fields: [originPudoPointId], references: [id])

  @@index([originPudoPointId])
  @@index([status])
}

model HubOperator {
  id          String          @id @default(cuid())
  email       String          @unique
  name        String
  pinHash     String
  role        HubOperatorRole @default(OPERATOR)
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  lastLoginAt DateTime?
}
